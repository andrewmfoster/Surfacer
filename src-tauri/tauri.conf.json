{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Surfacer",
  "mainBinaryName": "Surfacer",
  "version": "1.0.0",
  "identifier": "com.surfacer.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Surfacer",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#0b0f1c"
      },
      {
        "label": "tray",
        "url": "index.html?tray=1",
        "width": 360,
        "height": 490,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false,
        "backgroundColor": "#00000000"
      },
      {
        "label": "overlay",
        "url": "index.html?overlay=1",
        "width": 320,
        "height": 420,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "shadow": false,
        "backgroundColor": "#00000000"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data:; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-src 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/uploads/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "copyright": "© 2026 Andrew Foster",
    "shortDescription": "Personal project tracker",
    "longDescription": "Surfacer is a personal project tracker. One column per project, freeform cards, quick-add on the fly.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
